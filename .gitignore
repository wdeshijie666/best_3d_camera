CMakeUserPresets.json
CTestTestfile.cmake
_deps/
.cache/

# install/export 到仓库树内的目录（与 CMAKE_INSTALL_PREFIX 等一致时）
**/camera_3d_install/**
**/export/**

# --- 本地/运行时输出 ---
logs/
recv_images/
recon_img_save/
*.dmp
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.eggs/
*.egg-info/

# --- IDE / 系统杂项 ---
.vs/
.idea/
*.code-workspace
.DS_Store
Thumbs.db
Desktop.ini
# 勿全局忽略 *.log，以免误伤带 .log 后缀的说明文件；只忽略 logs/ 目录即可

# --- 包管理 / 杂项工作目录（若放在仓库内）---
vcpkg_installed/
conan/
.conan/
node_modules/

# 可选：整目录不纳入时取消下一行注释
# tmp_smoke_sdk_client/

# 本地打包备份（如误放在 libs/ 下）；需要入库的小 zip 用 git add -f
*.7z
*文本文档*.txt

# =============================================================================
