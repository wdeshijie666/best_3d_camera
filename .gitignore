*.dll
*.lai
*.la
# 预编译静态库如确需进仓库，使用: git add -f
*.a
*.lib
*.exe
*.out
*.app

# --- CMake 与多工作区构建目录（build/ 在任意子目录下均匹配）---
build/
build2/
build3/
build4/
build_*/
build_viewer/
build_vs2019/
build_nmake_cc/
out/
install/
dist/
cmake-build-*/
